---
import { Image } from 'astro:assets'
import logo from '../assets/logo.webp'
import Button from './Button.astro'
---

<header class="w-full h-30">
  <nav class="w-full bg-secondary">
    <div
      class="flex flex-wrap items-center justify-between mx-auto max-w-screen-2xl h-30 p-4 sm:px-8 2xl:p-0">
      <a href="/" class="flex items-center space-x-3 rtl:space-x-reverse">
        <Image src={logo} class="w-90 h-auto" alt="logo de Luana Cândido" />
      </a>

      <!-- Botón hamburguesa (solo mobile) -->
      <button
        id="menu-toggle"
        type="button"
        class="inline-flex items-center justify-end w-10 h-10 text-sm lg:hidden"
        aria-controls="navbar-default"
        aria-expanded="false"
        aria-label="Abrir menú principal">
        <!-- Icono hamburguesa -->
        <svg
          id="icon-open"
          class="w-6 h-6"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24">
          <path
            stroke="currentColor"
            stroke-linecap="round"
            stroke-width="2"
            d="M5 7h14M5 12h14M5 17h14"></path>
        </svg>

        <!-- Icono cerrar (X) -->
        <svg
          id="icon-close"
          class="fixed w-6 h-6 hidden z-20"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24">
          <path
            stroke="currentColor"
            stroke-linecap="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>

      <!-- Menú de navegación -->
      <div
        id="navbar-default"
        class="fixed inset-0 z-10 flex flex-col items-center justify-center w-full h-screen bg-secondary/95 backdrop-blur-xl transition-all duration-500 ease-out transform scale-95 opacity-0 pointer-events-none lg:static lg:opacity-100 lg:pointer-events-auto lg:h-auto lg:flex lg:w-auto lg:bg-transparent lg:scale-100"
        aria-hidden="true">
        <ul
          class="font-medium flex flex-col items-center p-4 mt-4 space-y-6 lg:space-y-0 lg:p-0 lg:flex-row lg:space-x-8 rtl:space-x-reverse lg:mt-0">
          <li>
            <a
              href="#about-me"
              data-section="about-me"
              class="block py-2 px-3 text-2xl rounded lg:p-0 lg:text-sm link-underline transition-colors duration-300 hover:text-accent">
              Sobre mim
            </a>
          </li>
          <li>
            <a
              href="#services"
              data-section="services"
              class="block py-2 px-3 text-2xl rounded lg:p-0 lg:text-sm link-underline transition-colors duration-300 hover:text-accent">
              Serviços
            </a>
          </li>
          <li>
            <a
              href="#contact"
              data-section="contact"
              class="block py-2 px-3 text-2xl rounded lg:p-0 lg:text-sm link-underline transition-colors duration-300 hover:text-accent">
              Contato
            </a>
          </li>
          <li>
            <Button
              class="mt-10 bg-black text-primary hover:bg-black/80 lg:mt-0"
            />
          </li>
        </ul>
      </div>
    </div>
  </nav>
</header>

<script>
  // =============================================
  // 1. MENÚ MÓVIL
  // =============================================
  const toggle = document.getElementById('menu-toggle')
  const menu = document.getElementById('navbar-default')
  const iconOpen = document.getElementById('icon-open')
  const iconClose = document.getElementById('icon-close')

  if (!toggle || !menu) throw new Error('Navbar elements not found')

  let isOpen = false

  const isDesktop = () => window.matchMedia('(min-width: 1024px)').matches

  function openMenu() {
    // Mostrar menú
    menu?.classList.remove('opacity-0', 'pointer-events-none', 'scale-95')
    menu?.classList.add('opacity-100', 'scale-100')

    // Accesibilidad
    menu?.setAttribute('aria-hidden', 'false')
    toggle?.setAttribute('aria-expanded', 'true')

    // Iconos
    iconOpen?.classList.add('hidden')
    iconClose?.classList.remove('hidden')

    isOpen = true
  }

  function closeMenu() {
    // Ocultar menú
    menu?.classList.add('opacity-0', 'pointer-events-none', 'scale-95')
    menu?.classList.remove('opacity-100', 'scale-100')

    // Accesibilidad
    menu?.setAttribute('aria-hidden', 'true')
    toggle?.setAttribute('aria-expanded', 'false')

    // Iconos
    iconOpen?.classList.remove('hidden')
    iconClose?.classList.add('hidden')

    isOpen = false
  }

  toggle.addEventListener('click', () => {
    isOpen ? closeMenu() : openMenu()
  })

  menu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      if (!isDesktop()) closeMenu()
    })
  })

  window.addEventListener('resize', () => {
    if (isDesktop()) {
      menu.classList.remove('opacity-0', 'pointer-events-none', 'scale-95')
      menu.classList.add('opacity-100', 'scale-100')

      menu.style.maxHeight = '' // (por si quedó algo viejo)
      isOpen = false
    } else {
      closeMenu()
    }
  })

  document.addEventListener('click', (e) => {
    if (
      !isDesktop() &&
      isOpen &&
      !menu.contains(e.target as Node) &&
      !toggle.contains(e.target as Node)
    ) {
      closeMenu()
    }
  })

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) {
      closeMenu()
      toggle.focus()
    }
  })

  // =============================================
  // 2. ACTIVE SECTION — IntersectionObserver
  // =============================================

  // Para mobile el activo tiene fondo; para desktop solo color
  // Usamos un atributo data en lugar de clases hardcodeadas en el HTML
  // para poder alternar limpiamente desde JS.

  const navLinks =
    document.querySelectorAll<HTMLAnchorElement>('a[data-section]')

  function setActive(sectionId: string) {
    navLinks.forEach((link) => {
      const isActive = link.dataset.section === sectionId

      // aria-current para accesibilidad
      link.setAttribute('aria-current', isActive ? 'page' : 'false')

      if (isActive) {
        link.classList.add('text-accent')
      } else {
        link.classList.remove('text-accent')
      }
    })
  }

  // Mapa sectionId → cuánto está visible (ratio)
  const visibilityMap = new Map<string, number>()

  // rootMargin "-40% 0px -40% 0px" hace que solo el centro del viewport
  // cuente como "visible", lo que da un highlight más preciso en landing pages
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        visibilityMap.set(entry.target.id, entry.intersectionRatio)
      })

      // La sección activa es la que tiene mayor ratio visible
      let maxRatio = 0
      let activeSectionId = ''

      visibilityMap.forEach((ratio, id) => {
        if (ratio > maxRatio) {
          maxRatio = ratio
          activeSectionId = id
        }
      })

      if (activeSectionId) setActive(activeSectionId)
    },
    {
      // Recorta el área de observación al centro del viewport
      rootMargin: '-30% 0px -20% 0px',
      // Reporta cambios con granularidad de 5%
      threshold: Array.from({ length: 21 }, (_, i) => i * 0.05)
    }
  )

  // Observar todas las secciones que tienen un link en el nav
  navLinks.forEach((link) => {
    const id = link.dataset.section
    if (!id) return
    const section = document.getElementById(id)
    if (section) {
      visibilityMap.set(id, 0)
      observer.observe(section)
    }
  })
</script>
