---
// Navbar.astro
---

<header class="w-full h-18">
  <nav class="fixed top-0 start-0 z-20 w-full bg-secondary">
    <div
      class="flex flex-wrap items-center justify-between mx-auto max-w-screen-xl h-18 p-4 sm:px-8">
      <a href="/" class="flex items-center space-x-3 rtl:space-x-reverse">
        <img
          src="/src/assets/laosdhasd.webp"
          class="w-50 h-auto"
          alt="logo de Luana Cândido"
        />
      </a>

      <!-- Botón hamburguesa (solo mobile) -->
      <button
        id="menu-toggle"
        type="button"
        class="inline-flex items-center justify-end w-10 h-10 text-sm text-body rounded-base md:hidden hover:bg-neutral-secondary-soft"
        aria-controls="navbar-default"
        aria-expanded="false"
        aria-label="Abrir menú principal">
        <!-- Icono hamburguesa -->
        <svg
          id="icon-open"
          class="w-6 h-6"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24">
          <path
            stroke="currentColor"
            stroke-linecap="round"
            stroke-width="2"
            d="M5 7h14M5 12h14M5 17h14"></path>
        </svg>

        <!-- Icono cerrar (X) -->
        <svg
          id="icon-close"
          class="w-6 h-6 hidden"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24">
          <path
            stroke="currentColor"
            stroke-linecap="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>

      <!-- Menú de navegación -->
      <div
        id="navbar-default"
        class="overflow-hidden md:!overflow-visible max-h-0 md:!max-h-none w-full md:w-auto bg-secondary transition-all duration-300 ease-in-out md:block"
        aria-hidden="true">
        <ul
          class="font-medium flex flex-col p-4 md:p-0 mt-4 border border-default rounded-base bg-neutral-secondary-soft md:flex-row md:space-x-8 rtl:space-x-reverse md:mt-0 md:border-0 md:bg-neutral-primary">
          <li>
            <a
              href="#home"
              data-section="home"
              class="block py-2 px-3 rounded hover:bg-neutral-tertiary md:hover:bg-transparent md:border-0 md:hover:text-fg-brand md:p-0">
              Home
            </a>
          </li>
          <li>
            <a
              href="#about-me"
              data-section="about-me"
              class="block py-2 px-3 rounded hover:bg-neutral-tertiary md:hover:bg-transparent md:border-0 md:hover:text-fg-brand md:p-0">
              Sobre mim
            </a>
          </li>
          <li>
            <a
              href="#services"
              data-section="services"
              class="block py-2 px-3 rounded hover:bg-neutral-tertiary md:hover:bg-transparent md:border-0 md:hover:text-fg-brand md:p-0">
              Serviços
            </a>
          </li>
          <li>
            <a
              href="#contact"
              data-section="contact"
              class="block py-2 px-3 rounded hover:bg-neutral-tertiary md:hover:bg-transparent md:border-0 md:hover:text-fg-brand md:p-0">
              Contato
            </a>
          </li>
        </ul>
      </div>
    </div>
  </nav>
</header>

<script>
  // =============================================
  // 1. MENÚ MÓVIL
  // =============================================
  const toggle = document.getElementById('menu-toggle')
  const menu = document.getElementById('navbar-default')
  const iconOpen = document.getElementById('icon-open')
  const iconClose = document.getElementById('icon-close')

  if (!toggle || !menu) throw new Error('Navbar elements not found')

  let isOpen = false

  const isDesktop = () => window.matchMedia('(min-width: 768px)').matches

  function openMenu() {
    menu.style.maxHeight = menu.scrollHeight + 'px'
    menu.setAttribute('aria-hidden', 'false')
    toggle.setAttribute('aria-expanded', 'true')
    iconOpen?.classList.add('hidden')
    iconClose?.classList.remove('hidden')
    isOpen = true
  }

  function closeMenu() {
    menu.style.maxHeight = '0px'
    menu.setAttribute('aria-hidden', 'true')
    toggle.setAttribute('aria-expanded', 'false')
    iconOpen?.classList.remove('hidden')
    iconClose?.classList.add('hidden')
    isOpen = false
  }

  toggle.addEventListener('click', () => {
    isOpen ? closeMenu() : openMenu()
  })

  menu.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      if (!isDesktop()) closeMenu()
    })
  })

  window.addEventListener('resize', () => {
    if (isDesktop() && isOpen) {
      closeMenu()
      menu.style.maxHeight = ''
    }
  })

  document.addEventListener('click', (e) => {
    if (
      !isDesktop() &&
      isOpen &&
      !menu.contains(e.target as Node) &&
      !toggle.contains(e.target as Node)
    ) {
      closeMenu()
    }
  })

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isOpen) {
      closeMenu()
      toggle.focus()
    }
  })

  // =============================================
  // 2. ACTIVE SECTION — IntersectionObserver
  // =============================================

  // Para mobile el activo tiene fondo; para desktop solo color
  // Usamos un atributo data en lugar de clases hardcodeadas en el HTML
  // para poder alternar limpiamente desde JS.

  const navLinks =
    document.querySelectorAll<HTMLAnchorElement>('a[data-section]')

  function setActive(sectionId: string) {
    navLinks.forEach((link) => {
      const isActive = link.dataset.section === sectionId

      // aria-current para accesibilidad
      link.setAttribute('aria-current', isActive ? 'page' : 'false')

      if (isActive) {
        link.classList.add('text-accent')
      } else {
        link.classList.remove('text-accent')
      }
    })
  }

  // Mapa sectionId → cuánto está visible (ratio)
  const visibilityMap = new Map<string, number>()

  // rootMargin "-40% 0px -40% 0px" hace que solo el centro del viewport
  // cuente como "visible", lo que da un highlight más preciso en landing pages
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        visibilityMap.set(entry.target.id, entry.intersectionRatio)
      })

      // La sección activa es la que tiene mayor ratio visible
      let maxRatio = 0
      let activeSectionId = ''

      visibilityMap.forEach((ratio, id) => {
        if (ratio > maxRatio) {
          maxRatio = ratio
          activeSectionId = id
        }
      })

      if (activeSectionId) setActive(activeSectionId)
    },
    {
      // Recorta el área de observación al centro del viewport
      rootMargin: '-30% 0px -20% 0px',
      // Reporta cambios con granularidad de 5%
      threshold: Array.from({ length: 21 }, (_, i) => i * 0.05)
    }
  )

  // Observar todas las secciones que tienen un link en el nav
  navLinks.forEach((link) => {
    const id = link.dataset.section
    if (!id) return
    const section = document.getElementById(id)
    if (section) {
      visibilityMap.set(id, 0)
      observer.observe(section)
    }
  })
</script>
