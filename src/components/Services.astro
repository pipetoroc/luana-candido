---

---

<section class="py-14 px-8 dark:bg-dark-secondary" id="services">
  <div class="max-w-screen-2xl mx-auto lg:grid lg:grid-cols-2 lg:gap-16">
    <h2 class="pb-10 text-5xl font-normal tracking-tight">
      Serviços que ofereço
    </h2>

    <!-- Acordeón 1: Avaliação neuropsicológica -->
    <div class="space-y-0">
      <div
        class="accordion-item max-w-screen-2xl mx-auto border-t border-default">
        <button
          class="accordion-trigger w-full flex items-center justify-between py-4 text-left"
          aria-expanded="false">
          <h2 class="text-2xl font-normal tracking-tight lg:text-3xl">
            Avaliação neuropsicológica
          </h2>
          <svg
            class="accordion-icon w-5 h-5 shrink-0 text-heading transition-transform duration-300"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24">
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="m19 9-7 7-7-7"></path>
          </svg>
        </button>

        <div
          class="accordion-content overflow-hidden max-h-0 transition-all duration-300 ease-in-out">
          <div class="pb-18 space-y-4">
            <div>
              <h3 class="pb-2 text-sm/tight font-bold tracking-tight">
                Indicação
              </h3>
              <p>
                Diagnóstico e acompanhamento de Transtorno do Déficit de Atenção
                e Hiperatividade (TDAH), Transtorno do Espectro Autista (TEA),
                demências, dificuldades escolares e transtornos psiquiátricos,
                entre outros.
              </p>
            </div>
            <div>
              <h3 class="pb-2 text-sm/tight font-bold tracking-tight">
                O que é avaliado
              </h3>
              <p>
                Memória, atenção, linguagem, funções executivas, aspectos
                emocionais/comportamentais e eficiência intelectual (QI) por
                meio de testes padronizados e entrevistas clínicas.
              </p>
            </div>
            <div>
              <h3 class="pb-2 text-sm/tight font-bold tracking-tight">
                Procedimento
              </h3>
              <ol class="list-decimal list-inside space-y-1">
                <li>Entrevista inicial (anamnese)</li>
                <li>Sessões de avaliação (4 a 10 encontros)</li>
                <li>Elaboração do laudo</li>
                <li>Devolutiva com orientações práticas</li>
              </ol>
            </div>
          </div>
        </div>
      </div>

      <!-- Acordeón 2: Reabilitação Cognitiva -->
      <div
        class="accordion-item max-w-screen-2xl mx-auto border-t border-default">
        <button
          class="accordion-trigger w-full flex items-center justify-between py-4 text-left"
          aria-expanded="false">
          <h2 class="text-2xl font-normal tracking-tight lg:text-3xl">
            Reabilitação Cognitiva
          </h2>
          <svg
            class="accordion-icon w-5 h-5 shrink-0 text-heading transition-transform duration-300"
            aria-hidden="true"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24">
            <path
              stroke="currentColor"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="m19 9-7 7-7-7"></path>
          </svg>
        </button>

        <div
          class="accordion-content overflow-hidden max-h-0 transition-all duration-300 ease-in-out">
          <div class="pb-18 space-y-4">
            <div>
              <h3 class="pb-2 text-sm/tight font-bold tracking-tight">
                Indicação
              </h3>
              <p>
                Reabilitação de funções cognitivas como memória, atenção,
                linguagem e funções executivas, em casos de lesões cerebrais,
                demências, Déficit de Atenção e Hiperatividade (TDAH) e
                Transtorno do Espectro Autista (TEA)
              </p>
            </div>
            <div>
              <h3 class="pb-2 text-sm/tight font-bold tracking-tight">
                Objetivo
              </h3>
              <p>
                Fortalecer habilidades cognitivas e desenvolver estratégias para
                melhorar o funcionamento no dia a dia.
              </p>
            </div>
            <div>
              <h3 class="pb-2 text-sm/tight font-bold tracking-tight">
                Beneficios
              </h3>
              <ul class="list-disc list-inside space-y-1">
                <li>Mais autonomia nas atividades diárias</li>
                <li>Compensação de dificuldades cognitivas</li>
                <li>Melhora da qualidade de vida</li>
              </ul>
            </div>
            <div>
              <h3 class="pb-2 text-sm/tight font-bold tracking-tight">
                Procedimento
              </h3>
              <ul class="list-disc list-inside space-y-1">
                <li>
                  Sessões individuais (online), em ciclos de 10 a 12 encontros
                </li>
                <li>Treino cognitivo com exercícios estruturados</li>
                <li>Estratégias práticas de compensação</li>
                <li>Psicoeducação para paciente e família</li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <!-- Borde inferior -->
      <div class="border-t max-w-screen-2xl mx-auto border-default"></div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.accordion-item').forEach((item) => {
    const trigger = item.querySelector('.accordion-trigger')
    const content = item.querySelector('.accordion-content')
    const icon = item.querySelector('.accordion-icon')

    if (!trigger || !content) return

    trigger.addEventListener('click', () => {
      const isOpen = trigger.getAttribute('aria-expanded') === 'true'

      // 👉 Cerrar TODOS
      document.querySelectorAll('.accordion-item').forEach((otherItem) => {
        const otherTrigger = otherItem.querySelector('.accordion-trigger')
        const otherContent = otherItem.querySelector('.accordion-content')
        const otherIcon = otherItem.querySelector('.accordion-icon')

        if (!otherTrigger || !otherContent) return

        otherContent.style.maxHeight = '0px'
        otherTrigger.setAttribute('aria-expanded', 'false')
        otherIcon?.classList.remove('rotate-180')
      })

      // 👉 Si estaba cerrado, abrirlo
      if (!isOpen) {
        content.style.maxHeight = content.scrollHeight + 'px'
        trigger.setAttribute('aria-expanded', 'true')
        icon?.classList.add('rotate-180')
      }
    })
  })
  const firstItem = document.querySelector('.accordion-item')

  if (firstItem) {
    const trigger = firstItem.querySelector('.accordion-trigger')
    const content = firstItem.querySelector('.accordion-content')
    const icon = firstItem.querySelector('.accordion-icon')

    if (trigger && content) {
      content.style.maxHeight = content.scrollHeight + 'px'
      trigger.setAttribute('aria-expanded', 'true')
      icon?.classList.add('rotate-180')
    }
  }
</script>
