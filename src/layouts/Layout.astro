---
import '../styles/global.css'
import '@fontsource-variable/lexend/wght.css'
import Analytics from '@vercel/analytics/astro'
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href="https://tusitio.com/" />

    <title>Neuropsicóloga em Faria Lima e Vila Mariana | Luana Cândido</title>

    <meta
      name="description"
      content="Neuropsicóloga em Faria Lima e Vila Mariana. Avaliações neuropsicológicas e reabilitação cognitiva com Luana Cândido. Agende sua consulta."
    />

    <!-- Open Graph -->
    <meta
      property="og:title"
      content="Neuropsicóloga em Faria Lima e Vila Mariana | Luana Cândido"
    />
    <meta
      property="og:description"
      content="Avaliações neuropsicológicas e reabilitação cognitiva com atendimento personalizado."
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://luacandido.com.br/" />
    <meta property="og:image" content="https://luacandido.com.br/preview.jpg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  body {
    font-family: 'Lexend Variable', sans-serif;
  }
</style>
